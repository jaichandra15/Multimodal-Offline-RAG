# ─────────────────────────────────────────────────────────────────────────────
# RAG System — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=offrag
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/offrag

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=phi3:mini
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=300

# ── Lightning AI — set this to your backend cloudspace URL  ───────────────────
# Example: https://8000-01jxxxxxxxxxxxxxxxx.cloudspaces.litng.ai
# Leave as http://localhost:8000 for purely local development.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
